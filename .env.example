MONGODB_URI=
MONGO_DB=bands_hackathon_db

BAND_API_KEY=
BAND_REST_URL=https://app.band.ai/api/v1

# Reuse Band room(s) instead of creating new rooms each investigation (required at 100/100 limit)
# Pick an existing room from https://app.band.ai — posts land there during demo
# Add your BAND_API_KEY agent to that room as a participant (required for API posts)
# BAND_REUSE_ROOM_ID=
# Quiet demo (default ON): never @mention Normalizer/Verdict — they auto-reply via LLM and burn quota.
# Evidence posts are scripted from Normalizer's Band key instead. Set 0 only for autonomous Normalizer.
# BAND_DEMO_QUIET=1
# Optional second room for Explanation Room (defaults to BAND_REUSE_ROOM_ID if unset)
# BAND_EXPLANATION_ROOM_ID=

# Internal Band agents already in the demo room (for @mentions in visible chat)
# BAND_INTERNAL_NORMALIZER_HANDLE=@zaraselim04/normaliezer
# BAND_INTERNAL_VERDICT_JUDGE_HANDLE=@zaraselim04/verdictjudge
# API keys from Band → each internal agent → copy key (required for visible chat posts)
# BAND_API_KEY_NORMALIZER=
# BAND_API_KEY_VERDICT_JUDGE=

# Optional — Room 1 Cause Room (3 distinct Band identities):
# BAND_API_KEY_CLAIM_TRACER=
# BAND_API_KEY_BACKEND_WITNESS=
# BAND_API_KEY_CAUSAL_JUDGE=

# Optional — Room 2 Localization Room (4 distinct Band identities):
# BAND_API_KEY_CONTROL_FLOW_INVESTIGATOR=
# BAND_API_KEY_POLICY_INVESTIGATOR=
# BAND_API_KEY_GUARD_INVESTIGATOR=
# BAND_API_KEY_LOCALIZATION_JUDGE=

FEATHERLESS_API_KEY=
AIMLAPI_KEY=

SUPERVISOR_AGENT_ID=
SUPERVISOR_AGENT_API_KEY=
SUPERVISOR_AGENT_HANDLE=@muhammadakbartr11/supervisor-agent

DOER_AGENT_ID=
DOER_AGENT_API_KEY=
DOER_AGENT_HANDLE=@muhammadakbartr11/doer-agent

TOOL_EXECUTOR_ID=
TOOL_EXECUTOR_API_KEY=
TOOL_EXECUTOR_HANDLE=@muhammadakbartr11/tool-executor-agent
